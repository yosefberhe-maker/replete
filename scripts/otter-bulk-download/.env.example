# Copy this file to ".env" and fill in your real values. Never commit .env.
#
# Your Otter Enterprise API key / bearer token.
# (Generate in Otter: Enterprise Settings -> API -> Generate Token.)
OTTER_API_KEY=your_otter_api_key_here

# Base URL for the Otter API. Override only if your Enterprise instance differs.
OTTER_BASE_URL=https://api.otter.ai/v1

# Optional: set ONLY if your tenant scopes conversations under a workspace id.
# When set, the script lists from /workspace/<id>/conversations instead of /conversations.
# OTTER_WORKSPACE_ID=
