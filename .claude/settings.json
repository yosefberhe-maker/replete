{
  "permissions": {
    "allow": ["Read", "Write", "Edit", "Bash", "Grep", "Glob", "WebSearch", "Agent"],
    "deny": ["Computer"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "type": "command",
        "command": "bash ~/.claude/hooks/pre-bash.sh",
        "timeout": 5
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "type": "command",
        "command": "bash ~/.claude/hooks/post-write.sh",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash ~/.claude/hooks/pre-stop.sh",
        "timeout": 5
      }
    ]
  }
}
