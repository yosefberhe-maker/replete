# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
# pnpm is the canonical package manager; npm lockfile is incidental
package-lock.json

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# replete app data (JSON storage for MVP)
/data/waitlist.json
/data/reddit-posts.json
/data/shared-profiles.json

# agent runtime artifacts (the seed JSONs are tracked; runtime output is not)
/.agent-session/task-log.jsonl
/.agent-session/new-papers.json
/.agent-session/validated-claims.json
/.agent-session/tests.passed
/.agent-session/test-results.log
/.agent-worktrees/

# typescript
*.tsbuildinfo
next-env.d.ts
