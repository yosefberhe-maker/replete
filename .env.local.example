# Replete environment variables
# Copy to .env.local and fill in. Restart `pnpm dev` after changes.

# Resend transactional email (free tier: 3,000 emails / month).
# Get a key at https://resend.com/api-keys
# Leave empty in dev to skip sending — signups will still be stored locally.
RESEND_API_KEY=

# Public site URL — used in metadata + email links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sender shown on outbound emails. Must be a domain you've verified in Resend.
RESEND_FROM="Replete <hello@replete.health>"

# Admin / Reddit-tool gate key. The dashboards check ?key=ADMIN_KEY.
ADMIN_KEY=change-me-in-production
